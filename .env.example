# Copy to .env and fill in. Only ANTHROPIC_API_KEY is required.
ANTHROPIC_API_KEY=sk-ant-...

# Optional: enable LangSmith tracing for observability (#12).
# LANGCHAIN_TRACING_V2=true
# LANGCHAIN_API_KEY=ls-...
# LANGCHAIN_PROJECT=fitness-multi-agent

# Optional: enable Langfuse tracing (#12). Point at your local self-hosted instance.
# Bring it up with: cd ops && docker compose -f langfuse-docker-compose.yml up -d
# LANGFUSE_PUBLIC_KEY=pk-lf-fitness-demo-public
# LANGFUSE_SECRET_KEY=sk-lf-fitness-demo-secret
# LANGFUSE_HOST=http://localhost:3567
